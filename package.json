{
  "name": "fementor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm --prefix apps/api run dev\" \"npm --prefix apps/web run dev\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "db:ps": "docker-compose ps",
    "db:migrate": "npm --prefix apps/api run db:migrate",
    "db:migrate:status": "npm --prefix apps/api run db:migrate:status",
    "db:seed:dev": "npm --prefix apps/api run db:seed:dev",
    "storage:test": "npm --prefix apps/api run storage:test",
    "start": "npm --prefix apps/api run start",
    "start:api": "npm --prefix apps/api run start",
    "start:web": "npm --prefix apps/web run start",
    "build:web": "npm --prefix apps/web run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
