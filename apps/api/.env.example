PORT=3300
DB_PATH=../../data/fementor.db
APP_RUNTIME_MODE=local
PUBLIC_SOURCE_DRIVER=sqlite
LOCAL_DEFAULT_ADMIN=1
ADMIN_EMAILS=

# Clerk
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
DEV_FAKE_USER_ID=

# Supabase Postgres
DATABASE_URL=postgresql://fementor:fementor@localhost:55432/fementor
PGSSL_DISABLE=1

# LLM
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Public question source sync
PUBLIC_SOURCE_REMOTE_BASE_URL=
PUBLIC_SOURCE_REMOTE_API_KEY=
PUBLIC_SOURCE_REMOTE_TIMEOUT_MS=15000

# Retrieval
SIRCHMUNK_BIN=
SIRCHMUNK_MODE=DEEP
SIRCHMUNK_WORK_PATH=../../data/.sirchmunk

# Resume parsing
RESUME_PDF_PARSER=volcengine
VOLC_ACCESSKEY=
VOLC_SECRETKEY=
VOLCENGINE_TIMEOUT_MS=120000
VOLCENGINE_OCR_PAGE_NUM=16
VOLCENGINE_OCR_PARSE_MODE=auto
VOLCENGINE_OCR_TABLE_MODE=markdown
VOLCENGINE_OCR_FILTER_HEADER=true
