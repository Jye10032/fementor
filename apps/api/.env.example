PORT=3300
DB_PATH=../../data/fementor.db

# Clerk
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
DEV_FAKE_USER_ID=

# Supabase Postgres
DATABASE_URL=
PGSSL_DISABLE=0

# LLM
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Retrieval
SIRCHMUNK_BIN=
SIRCHMUNK_MODE=DEEP
SIRCHMUNK_WORK_PATH=../../data/.sirchmunk

# Resume parsing
RESUME_PDF_PARSER=volcengine
VOLC_ACCESSKEY=
VOLC_SECRETKEY=
VOLCENGINE_TIMEOUT_MS=120000
VOLCENGINE_OCR_PAGE_NUM=16
VOLCENGINE_OCR_PARSE_MODE=auto
VOLCENGINE_OCR_TABLE_MODE=markdown
VOLCENGINE_OCR_FILTER_HEADER=true
